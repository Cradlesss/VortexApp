<!-- res/values/styles_coach.xml -->
<resources>

    <style name="Theme.Vortex.Coach.Material" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorSurface">?attr/vortexBgSecondary</item>
        <item name="colorOnSurface">?attr/vortexTextPrimary</item>
        <item name="materialCardViewStyle">@style/Widget.Vortex.Coach.Card</item>
        <item name="materialButtonStyle">@style/Widget.Vortex.Coach.Button</item>
        <item name="textAppearanceTitleMedium">@style/Text.Vortex.Coach.Title</item>
        <item name="textAppearanceBodyMedium">@style/Text.Vortex.Coach.Body</item>
    </style>

    <style name="Widget.Vortex.Coach.Card" parent="Widget.Material3.CardView.Elevated">
        <item name="contentPadding">20dp</item>
        <item name="cornerRadius">20dp</item>
        <item name="strokeWidth">1dp</item>
        <item name="strokeColor">?attr/vortexBgPrimary</item>
    </style>

    <style name="Text.Vortex.Coach.Title" parent="TextAppearance.Material3.TitleMedium">
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">?attr/vortexTextPrimary</item>
    </style>

    <style name="Text.Vortex.Coach.Body" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textColor">?attr/vortexTextPrimary</item>
        <item name="android:lineSpacingExtra">2dp</item>
    </style>

    <style name="Widget.Vortex.Coach.Button" parent="Widget.Material3.Button">
        <item name="android:minHeight">42dp</item>
        <item name="android:paddingStart">16dp</item>
        <item name="android:paddingEnd">16dp</item>
        <item name="android:insetLeft">0dp</item>
        <item name="android:insetRight">0dp</item>
        <item name="cornerRadius">12dp</item>

        <item name="backgroundTint">?attr/vortexBgPrimary</item>
        <item name="android:textColor">?attr/vortexTextPrimary</item>
        <item name="rippleColor">?attr/vortexRipple</item>
    </style>

</resources>
