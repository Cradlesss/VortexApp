<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.Vortex.Material" parent="Theme.MaterialComponents.DayNight.Dialog.Alert">
        <item name="colorPrimary">?attr/vortexUiMain</item>
        <item name="colorPrimaryContainer">?attr/vortexUiMain</item>
        <item name="colorOnPrimary">@color/white</item>

        <item name="colorSecondary">?attr/vortexUiMain</item>
        <item name="colorControlActivated">?attr/vortexUiMain</item>
        <item name="colorControlHighlight">?attr/vortexRipple</item>

        <item name="colorSurface">?attr/vortexBgSecondary</item>
        <item name="colorOnSurface">?attr/vortexTextPrimary</item>

        <item name="materialButtonStyle">@style/Widget.Vortex.MaterialButton</item>
        <item name="materialButtonOutlinedStyle">@style/Widget.Vortex.MaterialButton.Outlined</item>

        <item name="android:windowMinWidthMajor">90%</item>
        <item name="android:windowMinWidthMinor">90%</item>
    </style>

    <style name="Widget.Vortex.MaterialButton" parent="Widget.MaterialComponents.Button">
        <item name="cornerRadius">@dimen/corner_radius_md</item>
        <item name="backgroundTint">?attr/vortexButtonPurple</item>
        <item name="rippleColor">?attr/vortexRipple</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">@color/white</item>
    </style>

    <style name="Widget.Vortex.MaterialButton.Outlined" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="cornerRadius">@dimen/corner_radius_md</item>
        <item name="strokeColor">?attr/vortexUiMain</item>
        <item name="strokeWidth">@dimen/stroke_thin</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">?attr/vortexTextPrimary</item>
    </style>
</resources>
