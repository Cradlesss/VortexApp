<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/coach_card"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_margin="12dp"
    android:clipToPadding="false"
    android:padding="14dp"
    style="@style/Widget.Vortex.Coach.Card"
    app:cardBackgroundColor="?attr/vortexBgSecondary"
    app:cardCornerRadius="16dp"
    app:cardElevation="8dp">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:id="@+id/coach_counter"
            style="@style/Text.Vortex.Coach.Body"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:alpha="0.75"
            android:text="@string/coach_default_counter"
            android:paddingBottom="2dp"/>

        <TextView
            android:id="@+id/coach_title"
            style="@style/Text.Vortex.Coach.Title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/coach_default_title"
            android:maxLines="2"/>

        <TextView
            android:id="@+id/coach_text"
            style="@style/Text.Vortex.Coach.Body"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="@string/coach_default_text"
            android:maxWidth="320dp"
            android:maxLines="10"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="end"
            android:weightSum="3"
            android:layout_marginTop="10dp"
            android:baselineAligned="false">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/coach_prev"
                style="@style/Widget.Vortex.Coach.Button"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:maxLines="1"
                android:ellipsize="end"
                android:text="@string/prev"
                app:iconPadding="0dp"
                app:cornerRadius="12dp"
                app:backgroundTint="?attr/vortexBgSecondary"
                app:strokeWidth="1dp"
                app:strokeColor="?attr/vortexUiMain"
                android:layout_marginEnd="8dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/coach_cancel"
                style="@style/Widget.Vortex.Coach.Button"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:maxLines="1"
                android:ellipsize="end"
                android:text="@string/cancel"
                app:cornerRadius="12dp"
                app:backgroundTint="?attr/vortexBgSecondary"
                app:strokeWidth="1dp"
                app:strokeColor="?attr/vortexUiMain"
                android:layout_marginEnd="8dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/coach_next"
                style="@style/Widget.Vortex.Coach.Button"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:maxLines="1"
                android:ellipsize="end"
                android:text="@string/next"
                app:cornerRadius="12dp"
                app:backgroundTint="?attr/vortexUiMain" />
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
