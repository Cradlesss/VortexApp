<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
        xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        android:id="@+id/root_layout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="?attr/vortexBgPrimary"
        android:fitsSystemWindows="true">

    <TextView
            android:id="@+id/header_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginTop="28dp"
            android:text="@string/app_name"
            android:textColor="?attr/vortexUiMain"
            android:textSize="32sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

    <FrameLayout
            android:id="@+id/select_device_frame"
            android:layout_width="104dp"
            android:layout_height="56dp"
            android:layout_marginEnd="24dp"
            android:background="@drawable/bg_home_select_device"
            android:clickable="true"
            android:focusable="true"
            app:layout_constraintBottom_toBottomOf="@id/header_title"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/header_title">

        <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="6dp">

            <ImageButton
                    android:id="@+id/select_device_btn"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:background="@null"
                    android:clickable="false"
                    android:contentDescription="@string/select_device_btn_desc"
                    android:focusable="false"
                    android:padding="3dp"
                    android:src="@drawable/ic_select_device_btn"
                    app:tint="?attr/vortexTextPrimary" />

            <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="1dp"
                    android:text="@string/devices"
                    android:textColor="?attr/vortexTextSecondary"
                    android:textSize="11sp"
                    android:textStyle="bold" />
        </LinearLayout>
    </FrameLayout>

    <LinearLayout
            android:id="@+id/home_content_container"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginStart="24dp"
            android:layout_marginTop="52dp"
            android:layout_marginEnd="24dp"
            android:orientation="vertical"
            app:layout_constraintBottom_toTopOf="@id/brightness_container"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/header_title">

        <LinearLayout
                android:id="@+id/current_device_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_home_card"
                android:clickable="true"
                android:focusable="true"
                android:foreground="@drawable/fg_home_card_ripple"
                android:orientation="vertical"
                android:padding="18dp">

            <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/current_device"
                    android:textColor="?attr/vortexTextSecondary"
                    android:textSize="13sp" />

            <TextView
                    android:id="@+id/device_connection_status_text_view"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="@string/no_device_connected"
                    android:textColor="?attr/vortexTextPrimary"
                    android:textSize="20sp"
                    android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
                android:id="@+id/buttonsContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"
                android:background="@drawable/bg_home_card"
                android:orientation="vertical"
                android:padding="6dp">

            <LinearLayout
                    android:id="@+id/effects_btn"
                    android:layout_width="match_parent"
                    android:layout_height="74dp"
                    android:foreground="@drawable/fg_home_row_ripple"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="18dp"
                    android:paddingEnd="18dp">

                <FrameLayout
                        android:layout_width="38dp"
                        android:layout_height="38dp">

                    <ImageView
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_home_effects"
                            app:tint="?attr/vortexUiMain" />
                </FrameLayout>

                <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="14dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                    <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/effects"
                            android:textColor="?attr/vortexTextPrimary"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                    <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="@string/effects_desc"
                            android:textColor="?attr/vortexTextSecondary"
                            android:textSize="13sp" />
                </LinearLayout>

                <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/arrow"
                        android:textColor="?attr/vortexTextSecondary"
                        android:textSize="28sp" />
            </LinearLayout>

            <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginStart="18dp"
                    android:layout_marginEnd="18dp"
                    android:background="?attr/vortexSeparator" />

            <LinearLayout
                    android:id="@+id/solid_color_btn"
                    android:layout_width="match_parent"
                    android:layout_height="74dp"
                    android:foreground="@drawable/fg_home_row_ripple"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="18dp"
                    android:paddingEnd="18dp">

                <FrameLayout
                        android:layout_width="38dp"
                        android:layout_height="38dp">

                    <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_home_solid_color"
                            app:tint="?attr/vortexUiMain" />
                </FrameLayout>

                <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="14dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                    <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/solid_color"
                            android:textColor="?attr/vortexTextPrimary"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                    <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="@string/solid_color_desc"
                            android:textColor="?attr/vortexTextSecondary"
                            android:textSize="13sp" />
                </LinearLayout>

                <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/arrow"
                        android:textColor="?attr/vortexTextSecondary"
                        android:textSize="28sp" />
            </LinearLayout>
        </LinearLayout>

        <Space
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1" />

        <LinearLayout
                android:id="@+id/home_scene_preview_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"
                android:layout_marginBottom="30dp"
                android:background="@drawable/bg_home_card"
                android:orientation="vertical"
                android:padding="18dp">

            <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                <LinearLayout
                        android:id="@+id/home_output_text_container"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        app:layout_constraintEnd_toStartOf="@id/home_output_indicator"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent">

                <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingStart="8dp"
                        android:paddingTop="6dp"
                        android:paddingEnd="10dp"
                        android:paddingBottom="6dp">

                    <TextView
                            android:id="@+id/home_current_mode_label"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/current"
                            android:textColor="?attr/vortexTextSecondary"
                            android:textSize="12sp" />

                    <TextView
                            android:id="@+id/home_active_mode_text"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="@string/no_active_mode"
                            android:textColor="?attr/vortexTextPrimary"
                            android:textSize="20sp"
                            android:textStyle="bold" />
                </LinearLayout>

                    <LinearLayout
                            android:id="@+id/home_suggested_effect_row"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:foreground="@drawable/fg_home_suggested_ripple"
                            android:clickable="true"
                            android:focusable="true"
                            android:orientation="vertical"
                            android:paddingStart="8dp"
                            android:paddingTop="6dp"
                            android:paddingEnd="10dp"
                            android:paddingBottom="6dp">

                        <TextView
                                android:id="@+id/home_suggested_label"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/suggested"
                                android:textColor="?attr/vortexTextSecondary"
                                android:textSize="12sp" />

                        <TextView
                                android:id="@+id/home_suggested_mode_text"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:text="@string/suggested_base"
                                android:textColor="?attr/vortexTextPrimary"
                                android:textSize="16sp"
                                android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>

                <ImageView
                        android:id="@+id/home_output_indicator"
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:layout_marginStart="16dp"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_home_output_indicator"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:tint="?attr/vortexUiMain" />
            </androidx.constraintlayout.widget.ConstraintLayout>
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
            android:id="@+id/brightness_container"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="16dp"
            android:background="@drawable/bg_rounded_border"
            android:backgroundTint="?attr/vortexBgSecondary"
            android:elevation="8dp"
            android:orientation="vertical"
            android:padding="14dp"
            app:layout_constraintBottom_toTopOf="@id/bottom_nav_container"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent">

        <TextView
                android:id="@+id/brightness_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="@string/brightness_seek_bar_desc"
                android:textColor="?attr/vortexTextPrimary"
                android:textSize="16sp"
                android:textStyle="bold" />

        <SeekBar
                android:id="@+id/brightness_seek_bar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:progress="128"
                android:progressTint="?attr/vortexUiMain"
                android:thumbTint="?attr/vortexUiMain" />
    </LinearLayout>

    <FrameLayout
            android:id="@+id/bottom_nav_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bottom_nav_background"
            android:elevation="8dp"
            android:paddingLeft="12dp"
            android:paddingRight="12dp"
            app:layout_constraintBottom_toBottomOf="parent">

        <com.google.android.material.bottomnavigation.BottomNavigationView
                android:id="@+id/bottom_navigation"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@android:color/transparent"
                app:elevation="0dp"
                app:itemIconTint="@color/bottom_nav_item_tint"
                app:itemTextColor="@color/bottom_nav_item_tint"
                app:labelVisibilityMode="labeled"
                app:menu="@menu/bottom_navigation_menu" />
    </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
