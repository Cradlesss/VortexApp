<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:padding="30dp"
    android:background="@drawable/bg_dialog">

    <TextView
        android:id="@+id/title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="?attr/vortexTextPrimary"
        android:textStyle="bold"
        android:textSize="20sp"/>

    <TextView
        android:id="@+id/message"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:lineSpacingExtra="2dp"
        android:text=""
        android:textSize="16sp"
        android:textColor="?attr/vortexTextPrimary"
        android:layout_marginTop="8dp"
        android:autoLink="web"
        android:linksClickable="true"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:orientation="horizontal"
        android:gravity="end">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_cancel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            style="?attr/materialButtonOutlinedStyle"
            android:text="@string/cancel"
            android:textAllCaps="false"
            android:textColor="?attr/vortexTextPrimary"
            app:strokeColor="?attr/vortexUiMain"
            app:strokeWidth="@dimen/stroke_thin"
            app:cornerRadius="@dimen/corner_radius_md"
            android:layout_marginEnd="12dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_primary"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/ok"
            android:textAllCaps="false"
            android:textColor="?attr/vortexTextPrimary"
            app:cornerRadius="@dimen/corner_radius_md"
            app:rippleColor="?attr/vortexRipple"
            app:backgroundTint="?attr/vortexButtonPurple"/>
    </LinearLayout>
</LinearLayout>